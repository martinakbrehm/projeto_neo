# ==============================================================
# Neo Energia — Macro de Consulta de Titularidade
# Arquivo de configuração de credenciais
# ==============================================================
# COMO USAR:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
#   Depois preencha os valores reais abaixo.
#   NUNCA versione o arquivo .env no Git.
# ==============================================================

# --- Servidor SSH (jump host / bastion) -----------------------

# Usuário do servidor SSH
SSH_USER=root

# IP ou hostname público do servidor SSH
SSH_SERVER=000.000.000.000

# Senha do servidor SSH
SSH_PASSWORD=sua_senha_aqui

# Fingerprint da chave do servidor para modo batch (sem prompt interativo).
# Como obter: execute plink -pw SUA_SENHA root@SEU_SERVIDOR "echo ok"
# Na primeira conexão o plink exibirá a chave — copie no formato abaixo.
# Exemplo: ssh-ed25519 255 SHA256:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SSH_HOST_KEY=

# --- Túnel SSH (port forwarding local → API interna) ----------

# Porta local que será aberta na sua máquina para o túnel
LOCAL_PORT=5000

# IP da API dentro da rede interna (acessível pelo servidor SSH)
REMOTE_HOST=10.0.0.0

# Porta da API no host remoto (normalmente HTTP=80)
REMOTE_PORT=80